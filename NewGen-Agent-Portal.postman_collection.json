            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"password\": \"StrongPass@1\",\n  \"confirmPassword\": \"DifferentPass@2\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
