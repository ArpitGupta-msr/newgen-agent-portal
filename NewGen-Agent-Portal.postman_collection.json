{
  "info": {
    "name": "NewGen Agent Portal",
    "description": "API collection for NewGen Insurance Agent Portal microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "agent_service_url", "value": "http://localhost:8081" },
    { "key": "otp_service_url", "value": "http://localhost:8083" },
    { "key": "login_service_url", "value": "http://localhost:8085" },
    { "key": "agency_code", "value": "AG001" },
    { "key": "otp_code", "value": "" }
  ],
  "item": [
    {
      "name": "1. Agent Registration Flow",
      "item": [
        {
          "name": "1.1 Sign Up - New Agent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/signup", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"AG010\",\n  \"name\": \"Test Agent\",\n  \"role\": \"AGENT\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has agentId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.agentId).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Sign Up - Duplicate Agency Code (Error)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/signup", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"AG001\",\n  \"name\": \"Duplicate Agent\",\n  \"role\": \"AGENT\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Sign Up - Missing Fields (Validation Error)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/signup", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"\",\n  \"name\": \"\",\n  \"role\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Has validation error message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Please provide a valid');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Agency Code Validation & Consent",
      "item": [
        {
          "name": "2.1 Validate Agency Code - Valid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/validate-agency-code", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "validate-agency-code"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Agency code is valid', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.valid).to.be.true;",
                  "    pm.expect(jsonData.agentName).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Validate Agency Code - Invalid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/validate-agency-code", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "validate-agency-code"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"INVALID_CODE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error message matches spec', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.eql('Incorrect agency code, please enter a valid code.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Record Consent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/consent", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "consent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"consentGiven\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Consent recorded', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Consent recorded');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. OTP Verification",
      "item": [
        {
          "name": "3.1 Generate OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{otp_service_url}}/newgen/otp/generate", "host": ["{{otp_service_url}}"], "path": ["newgen", "otp", "generate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('OTP sent successfully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.otpSent).to.be.true;",
                  "});",
                  "// Extract OTP from message for next request",
                  "var msg = pm.response.json().message;",
                  "var otp = msg.match(/\\d{6}/);",
                  "if (otp) { pm.collectionVariables.set('otp_code', otp[0]); }"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Validate OTP - Correct",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{otp_service_url}}/newgen/otp/validate", "host": ["{{otp_service_url}}"], "path": ["newgen", "otp", "validate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"otpCode\": \"{{otp_code}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('OTP validated with welcome message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.valid).to.be.true;",
                  "    pm.expect(jsonData.message).to.include('Your verification has been done successfully');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Validate OTP - Incorrect",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{otp_service_url}}/newgen/otp/validate", "host": ["{{otp_service_url}}"], "path": ["newgen", "otp", "validate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"otpCode\": \"000000\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error message matches spec', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.eql('Incorrect OTP, please try again');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{otp_service_url}}/newgen/otp/resend", "host": ["{{otp_service_url}}"], "path": ["newgen", "otp", "resend"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OTP resent or interval error', function () {",
                  "    pm.expect([200, 429]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Credential Setup - Password",
      "item": [
        {
          "name": "4.1 Set Password - Success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/set-password", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "set-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"password\": \"StrongPass@1\",\n  \"confirmPassword\": \"StrongPass@1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
