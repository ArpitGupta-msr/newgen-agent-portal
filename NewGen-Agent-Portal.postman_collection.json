                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.message).to.include('set up successfully');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Set Password - Mismatch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
