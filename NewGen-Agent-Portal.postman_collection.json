            "url": { "raw": "{{agent_service_url}}/newgen/agents/set-mpin", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "set-mpin"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"AG002\",\n  \"mpin\": \"12\",\n  \"confirmMpin\": \"12\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
