            }
          ]
        },
        {
          "name": "4.3 Set Password - Weak Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{agent_service_url}}/newgen/agents/set-password", "host": ["{{agent_service_url}}"], "path": ["newgen", "agents", "set-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agencyCode\": \"{{agency_code}}\",\n  \"password\": \"weak\",\n  \"confirmPassword\": \"weak\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error: Password criteria not met', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Password does not meet the recommended criteria');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
